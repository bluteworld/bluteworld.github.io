{
  "rules": {
    "leaderboard": {
      "$date": {
        ".read": true,
        "$uuid": {
          ".write": "!data.exists()",
          ".validate": "newData.hasChildren(['questionsAsked']) && newData.child('questionsAsked').isNumber() && newData.child('questionsAsked').val() >= -50 && newData.child('questionsAsked').val() <= 200"
        }
      }
    },
    "questionLog": {
      "$date": {
        "$uuid": {
          ".write": true,
          ".read": true
        }
      }
    },
    "unansweredQuestions": {
      "$date": {
        "$uuid": {
          ".write": true,
          ".read": false
        }
      }
    },
    "feedback": {
      "$date": {
        "$uuid": {
          ".write": true,
          ".read": false
        }
      }
    }
  }
}
